<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="24dp"
    android:background="@drawable/bg_question_item"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtQuestionNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question 1"
        android:textColor="#5B8FD9"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtQuestionContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Question text goes here..."
        android:textColor="#1A3A5C"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <RadioGroup
        android:id="@+id/radioGroupOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioOptionA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Option A"
            android:textColor="#333333"
            android:padding="8dp"
            android:layout_marginBottom="4dp" />

        <RadioButton
            android:id="@+id/radioOptionB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Option B"
            android:textColor="#333333"
            android:padding="8dp"
            android:layout_marginBottom="4dp" />

        <RadioButton
            android:id="@+id/radioOptionC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Option C"
            android:textColor="#333333"
            android:padding="8dp"
            android:layout_marginBottom="4dp" />

        <RadioButton
            android:id="@+id/radioOptionD"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Option D"
            android:textColor="#333333"
            android:padding="8dp" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/explanationLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="12dp">
        
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtResultStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct!"
            android:textColor="#299D2D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explanation text here..."
            android:textColor="#666666"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
