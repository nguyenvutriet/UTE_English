<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6">

    <LinearLayout android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:background="#F2F2F2"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#DCDCDC"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_home"
                app:tint="#222222" />

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trang chủ"
                android:textColor="#111111"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_book"
                app:tint="#222222" />

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kho từ"
                android:textColor="#111111"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_user"
                app:tint="#222222" />

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tài khoản"
                android:textColor="#111111"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

<!--    <ImageView android:id="@+id/ivFloating"-->
<!--        android:layout_width="100dp"-->
<!--        android:layout_height="100dp"-->
<!--        android:layout_marginEnd="14dp"-->
<!--        android:layout_marginBottom="10dp"-->
<!--        android:background="#FFF3E6"-->
<!--        android:padding="10dp"-->
<!--        android:src="@drawable/stress"-->
<!--        app:layout_constraintBottom_toTopOf="@id/bottomBar"-->
<!--        app:layout_constraintEnd_toEndOf="parent" />-->

    <ScrollView android:id="@+id/mainScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="#ECECEC"
                android:gravity="bottom|start"
                android:paddingHorizontal="16dp"
                android:paddingBottom="10dp"
                android:text="UTE-ENGLISH"
                android:textColor="#0A1B75"
                android:textSize="36sp"
                android:textStyle="bold" />

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="#EFE59A"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hello, Mai 🥰&#10;Keep learning today\!"
                    android:textColor="#3C3C3C"
                    android:textSize="20sp"
                    android:textStyle="italic" />

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="46dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_tree" />

            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Từ điển"
                    android:textColor="#222222"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cài đặt ⚙"
                    android:textColor="#A0A0A0"
                    android:textSize="22sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#1B4DDA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Tra từ"
                    android:textColor="#9E9E9E"
                    android:textSize="15sp"/>

            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nguồn học"
                    android:textColor="#222222"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cách học ⓘ"
                    android:textColor="#1141FF"
                    android:textSize="20sp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#FBEFF3"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">

                    <!-- Hình banner -->
                    <ImageView
                        android:id="@+id/imageBanner"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_banner" />

                    <!-- Chữ -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Trở thành bậc thầy anh văn&#10;chỉ trong 1 ngày"
                        android:textColor="#FF2B2B"
                        android:textSize="16sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:paddingHorizontal="12dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        app:cardBackgroundColor="#74C400"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="☑"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Bài tập"
                        android:textColor="#222222"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        app:cardBackgroundColor="#2CB8D0"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="📖"
                            android:textSize="30sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Đọc sách"
                        android:textColor="#222222"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnGrammar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        app:cardBackgroundColor="#1E6DE8"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="abc✓"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Ngữ pháp"
                        android:textColor="#222222"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        app:cardBackgroundColor="#4FCBB8"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="📑"
                            android:textSize="30sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="6dp"
                        android:text="Bộ từ vựng"
                        android:textColor="#222222"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        app:cardBackgroundColor="#F03A45"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="▶"
                            android:textColor="#FFFFFF"
                            android:textSize="32sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Video"
                        android:textColor="#222222"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        app:cardBackgroundColor="#6B83BC"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="📚"
                            android:textSize="28sp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Từ điển"
                        android:textColor="#222222"
                        android:textSize="24sp" />
                </LinearLayout>
            </GridLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>