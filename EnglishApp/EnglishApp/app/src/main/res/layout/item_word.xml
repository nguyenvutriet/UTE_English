<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    card:cardCornerRadius="12dp"
    card:cardElevation="3dp"
    card:cardUseCompatPadding="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- WORD + STAR -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtWord"
                android:text="American"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2A5BD7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/btnStar"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/btn_star_big_off"/>

        </RelativeLayout>


        <!-- TYPE -->

        <TextView
            android:id="@+id/txtType"
            android:text="adjective"
            android:textSize="13sp"
            android:textColor="#666"
            android:layout_marginTop="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


        <!-- UK PRONUNCIATION -->

        <LinearLayout
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:text="UK"
                android:textSize="14sp"
                android:textColor="#444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/btnSpeakUk"
                android:src="@drawable/ic_volume"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/txtUk"
                android:text="/əˈmer.ɪ.kən/"
                android:textSize="14sp"
                android:textColor="#444"
                android:layout_marginStart="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- US PRONUNCIATION -->

        <LinearLayout
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:text="US"
                android:textSize="14sp"
                android:textColor="#444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/btnSpeakUs"
                android:src="@drawable/ic_volume"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/txtUs"
                android:text="/əˈmer.ɪ.kən/"
                android:textSize="14sp"
                android:textColor="#444"
                android:layout_marginStart="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- MEANING -->

        <TextView
            android:id="@+id/txtMeaning"
            android:text="thuộc nước Mỹ"
            android:layout_marginTop="12dp"
            android:textSize="14sp"
            android:textColor="#555"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>