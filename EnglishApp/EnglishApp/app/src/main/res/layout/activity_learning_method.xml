<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/learningMethodRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8E8E8">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#6A6A6A" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_cachhoc" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Spaced Repetition là gì?"
                android:textColor="#1E1E1E"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="Phương pháp lặp lại ngắt quãng được đặt nền tảng bởi Herman Ebbinghaus, người đã đưa ra giả thuyết rằng việc mất thông tin theo thời gian tuân theo một đường cong lãng quên, nhưng việc quên đó có thể điều chỉnh bằng sự lặp lại dựa trên khả năng ghi nhớ một cách chủ động. Lặp lại ngắt quãng là một phương pháp mà đối tượng được yêu cầu chủ động nhớ lại sự việc nhất định với khoảng thời gian tăng dần mỗi khi sự việc đó được trình bày hoặc nói ra. Nếu đối tượng có thể nhớ lại thông tin một cách chính xác, thời gian sẽ được nhân đôi giúp họ giữ được thông tin lưu mới trong tâm trí dễ nhớ lại trong tương lai. (*)"
                android:textAlignment="viewStart"
                android:textColor="#1E1E1E"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Các cấp độ nhớ"
                android:textColor="#1E1E1E"
                android:textSize="25sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#EFEFEF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*">

                    <TableRow android:background="#A8D4EE">

                        <TextView
                            android:gravity="center"
                            android:padding="10dp"
                            android:text="Cấp độ nhớ"
                            android:textColor="#1E1E1E"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:gravity="center"
                            android:padding="10dp"
                            android:text="Thời gian ôn tập"
                            android:textColor="#1E1E1E"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </TableRow>

                    <TableRow android:background="#F7F7F7">
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Cấp độ 1"
                            android:textSize="18sp" />
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Sau 2 giờ"
                            android:textSize="18sp" />
                    </TableRow>

                    <TableRow android:background="#EBEBEB">
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Cấp độ 2"
                            android:textSize="18sp" />
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Sau 1 ngày"
                            android:textSize="18sp" />
                    </TableRow>

                    <TableRow android:background="#F7F7F7">
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Cấp độ 3"
                            android:textSize="18sp" />
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Sau 2 ngày"
                            android:textSize="18sp" />
                    </TableRow>

                    <TableRow android:background="#EBEBEB">
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Cấp độ 4"
                            android:textSize="18sp" />
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Sau 3 ngày"
                            android:textSize="18sp" />
                    </TableRow>

                    <TableRow android:background="#F7F7F7">
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Cấp độ 5"
                            android:textSize="18sp" />
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Sau 5 ngày"
                            android:textSize="18sp" />
                    </TableRow>

                    <TableRow android:background="#EBEBEB">
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Nhớ sâu"
                            android:textSize="20sp" />
                        <TextView
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="Sau 8 ngày"
                            android:textSize="20sp" />
                    </TableRow>
                </TableLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="(*) https://en.wikipedia.org/wiki/Spaced_repetition"
                android:textColor="#666666"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

