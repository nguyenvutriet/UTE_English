<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_leaderboard"
    android:padding="16dp">

    <LinearLayout
        android:orientation="vertical"
        android:background="#F6D5D5"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Ribbon Banner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEADERBOARD"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:paddingLeft="40dp"
            android:paddingRight="40dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="@drawable/bg_ribbon"/>
        <TextView
            android:id="@+id/txtMyScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Score: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"/>
        <TextView
            android:id="@+id/txtMyRank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Rank: #0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#C54D4D"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"/>
        <!-- Leaderboard list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"/>

    </LinearLayout>

</LinearLayout>